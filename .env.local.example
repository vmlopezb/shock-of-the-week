# Copy this file to .env.local and fill in the values from your Supabase project
# (Project Settings -> API in the Supabase dashboard).

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Secret — service_role key (same API settings page, marked "secret").
# Never prefix this with NEXT_PUBLIC_: it bypasses RLS and manages auth.users,
# and must only ever be read server-side (used by admin delete actions).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key
